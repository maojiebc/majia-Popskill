    "App: Popskill v%@\nmacOS: %@\n\n<!-- 描述问题。若 app 崩溃过，请附上 ~/Library/Logs/DiagnosticReports 里最新的 Popskill-*.ips 文件 -->\n": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "App: Popskill v%1$@\nmacOS: %2$@\n\n<!-- Describe the issue. If the app has crashed, please attach the latest Popskill-*.ips file from ~/Library/Logs/DiagnosticReports -->\n"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "App: Popskill v%@\nmacOS: %@\n\n<!-- 描述问题。若 app 崩溃过，请附上 ~/Library/Logs/DiagnosticReports 里最新的 Popskill-*.ips 文件 -->\n"
          }
        }
      }
    },
